# =============================================================================
# discord-mod-bot — example environment file
# Copy this to .env and fill in values. .env is gitignored.
#
# NOTE: DISCORD_TOKEN is NOT here — the token is encrypted at rest in
# token.enc. Run `python setup_token.py` once to create it. See README.
# =============================================================================

# --- Optional: Guild & channel/role IDs -----------------------------------
# These seed your home/dev guild only. In multi-tenant mode every guild
# configures its own values via /config set; leave these blank to disable
# any global fallback.

GUILD_ID=                  # primary guild ID (used for fast slash-command sync on startup)
MOD_LOG_CHANNEL_ID=        # channel for Medium-severity logs
MOD_ALERTS_CHANNEL_ID=     # channel for Severe-severity alerts (admin pings)
ADMIN_ROLE_ID=             # role to ping on Severe alerts
MUTED_ROLE_ID=             # optional fallback if Discord native timeouts fail

# --- Optional: Web dashboard ---------------------------------------------
# Omit DASHBOARD_SECRET to disable the dashboard entirely. When set, the bot
# starts a FastAPI/uvicorn web UI bound to 127.0.0.1 (localhost-only).
# DASHBOARD_SECRET is BOTH the cookie-signing key AND the login password —
# use a long random string (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`).

DASHBOARD_SECRET=
DASHBOARD_PORT=8080

# --- Optional: keep_alive Flask uptime endpoint ---------------------------
# Used on free-tier hosts (Replit, Railway) so an external uptime monitor
# can ping a public URL to keep the worker hot. Binds to 0.0.0.0:$PORT.
# WARNING: defaults to 8080 — same as DASHBOARD_PORT. If you run both
# locally, set PORT to a different value (e.g. 8081).

PORT=
